# =============================================================================
#  Órbita — Variáveis para o RAILWAY (cole em Variables, uma por linha)
# -----------------------------------------------------------------------------
#  O Railway INJETA sozinho (não cole estas): DATABASE_URL, REDIS_URL, PORT
#  — basta adicionar os plugins PostgreSQL e Redis no projeto e linká-los.
# =============================================================================

# ----- AMBIENTE -----
NODE_ENV=production
APP_VERSION=1.0.0
BODY_LIMIT=25mb

# ----- AUTH / JWT (gere com: openssl rand -hex 32) -----
JWT_SECRET=COLE_um_segredo_forte_de_64_hex
JWT_REFRESH_SECRET=COLE_outro_segredo_forte_de_64_hex
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=2592000

# ----- CORS / URL pública do FRONT (domínio do Netlify) -----
# Ex.: https://orbita-app.netlify.app  (sem barra no final)
WEB_ORIGIN=https://SEU_SITE.netlify.app
PUBLIC_BASE_URL=https://SEU_BACKEND.up.railway.app

# ----- STRIPE (dashboard.stripe.com) -----
STRIPE_SECRET_KEY=sk_test_ou_sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_BUSINESS=price_...
STRIPE_API_BASE_URL=https://api.stripe.com
BILLING_SUCCESS_URL=https://SEU_SITE.netlify.app/?billing=success
BILLING_CANCEL_URL=https://SEU_SITE.netlify.app/?billing=cancel

# ----- META WHATSAPP (developers.facebook.com) -----
META_VERIFY_TOKEN=COLE_um_token_qualquer_que_voce_inventa
WHATSAPP_ACCESS_TOKEN=EAAG...token_permanente
WHATSAPP_PHONE_NUMBER_ID=123456789012345
WHATSAPP_APP_SECRET=app_secret_para_validar_webhook

# ----- OPENAI (apenas áudio/OCR; texto funciona sem) -----
OPENAI_API_KEY=sk-...
OPENAI_MODEL_TRANSCRIBE=whisper-1
OPENAI_MODEL_VISION=gpt-4o-mini

# ----- PLUGGY (opcional; sem isto, Open Finance roda em SANDBOX) -----
PLUGGY_CLIENT_ID=
PLUGGY_CLIENT_SECRET=
PLUGGY_API_BASE_URL=https://api.pluggy.ai
PLUGGY_CONNECT_URL=https://connect.pluggy.ai
PLUGGY_WEBHOOK_SECRET=
PLUGGY_WEBHOOK_ENABLED=true
